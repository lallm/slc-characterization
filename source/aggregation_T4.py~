# -----------------------------------------------------------------------------
# Helper function: calculate RMSD from centroid
# -----------------------------------------------------------------------------
def calculate_rmsd_from_centroid(group, coord_prefix):
    """
    Calculates RMSD of atomic coordinates relative to their centroid.
    """
    coord_cols = [f'{coord_prefix}_CoordinateX', f'{coord_prefix}_CoordinateY', f'{coord_prefix}_CoordinateZ']
    
    # Ensure all coordinate columns exist and there's at least one valid row
    valid_coords_df = group.dropna(subset=coord_cols)
    if not all(col in group.columns for col in coord_cols) or valid_coords_df.empty:
        return np.nan
    
    coords = valid_coords_df[coord_cols].values
    centroid = np.mean(coords, axis=0)
    return np.sqrt(np.mean(np.sum((coords - centroid)**2, axis=1)))

# -----------------------------------------------------------------------------
# Helper function: calculate Planarity RMSD
# -----------------------------------------------------------------------------
def calculate_rmsd_to_best_fit_plane(group, coord_prefix):
    """
    Calculates RMSD of atomic coordinates to the best-fit plane.
    """
    coord_cols = [f'{coord_prefix}_CoordinateX', f'{coord_prefix}_CoordinateY', f'{coord_prefix}_CoordinateZ']
    
    # Ensure all coordinate columns exist and there are at least 3 valid rows for plane fitting
    valid_coords_df = group.dropna(subset=coord_cols)
    if not all(col in group.columns for col in coord_cols) or valid_coords_df.shape[0] < 3:
        return np.nan
    
    coords = valid_coords_df[coord_cols].values
    centroid = np.mean(coords, axis=0)
    
    # SVD to find the normal vector of the best-fit plane
    _, _, vh = np.linalg.svd(coords - centroid, full_matrices=False)
    normal = vh[-1] # The last row of vh is the normal vector
    
    distances = np.abs(np.dot(coords - centroid, normal))
    return np.sqrt(np.mean(distances**2))

# -----------------------------------------------------------------------------
# Helper function: Plot Feature Distributions
# -----------------------------------------------------------------------------
def plot_feature_distributions(df, columns_to_plot, main_title, filename, title_suffixes=None):
    """
    Generates and saves a grid of histogram plots for specified features.
    """
    if not columns_to_plot:
        print(f"No features to plot for '{main_title}'. Skipping.")
        return

    print(f"Generating plot: '{main_title}'...")
    n_plots = len(columns_to_plot)
    n_cols = min(4, math.ceil(math.sqrt(n_plots)))
    n_rows = math.ceil(n_plots / n_cols)

    fig, axes = plt.subplots(n_rows, n_cols, figsize=(n_cols * 5, n_rows * 4), squeeze=False)
    axes = axes.flatten()

    for i, col in enumerate(columns_to_plot):
        ax = axes[i]
        # Replace inf/-inf with NaN and drop NaNs for plotting
        plot_data = df[col].replace([np.inf, -np.inf], np.nan).dropna().infer_objects(copy=False)
        
        if not plot_data.empty:
            suffix = title_suffixes.get(col, '') if title_suffixes else ''
            sns.histplot(plot_data, kde=True, ax=ax, bins=30)
            ax.set_title(f"{col}\n{suffix}".strip(), fontsize=10)
        else:
            ax.set_title(f"{col}\n(No Data)", fontsize=10)
            ax.axis('off') # Turn off axis for empty plots

    # Turn off any unused subplots
    for j in range(n_plots, len(axes)):
        axes[j].axis('off')

    plt.tight_layout(rect=[0, 0.03, 1, 0.95]) # Adjust layout to make space for suptitle
    fig.suptitle(main_title, fontsize=16)
    plt.savefig(filename, dpi=150)
    plt.close(fig) # Close the figure to free up memory
    print(f"  Plot saved to '{filename}'.")

# Helper for proportion calculation
PSEUDOCOUNT = 1.5
SUM_SMOOTHING = 3
def calculate_proportions(df, group_col, prefix):
    """
    Calculates proportions of categories within a group_col, adding a pseudocount.
    """
    counts = df.groupby(["ExpID", group_col]).size().unstack(fill_value=0)
    counts_pseudo = counts + PSEUDOCOUNT
    
    # Calculate the sum of original counts and add 3 (the denominator)
    denominator = counts.sum(axis=1) + SUM_SMOOTHING
    
    proportions = counts_pseudo.div(denominator, axis=0).add_prefix(prefix)
    return proportions.reset_index()

# -----------------------------------------------------------------------------
# Main Script Execution
# -----------------------------------------------------------------------------
if __name__ == "__main__":
    # -----------------------------------------------------------------------------
    # Step 1: Read in the Datasets
    # -----------------------------------------------------------------------------
    print("## Step 1: Reading datasets")
    
    base_path = "/home/lisa/PhD/sciwrk/Literatur_GNN/Python/EGAT_PPI/Data/aggregation_tabular/data/"
    df_ppi = pd.read_csv(f"{base_path}mlDIA_PPI.csv")
    df_residues = pd.read_csv(f"{base_path}mlDIA_AA_residue_properties.csv")
    df_contacts = pd.read_csv(f"{base_path}mlDIA_Contacts_T4.csv")

    print(f"  T2 (PPI Complexes): {df_ppi.shape}")
    print(f"  T3 (Residue Properties): {df_residues.shape}")
    print(f"  T4 (Residue Contacts): {df_contacts.shape}")

    # Filter all tables for ExpIDs that have at least one interface residue
    expids_with_interface = df_residues[df_residues['MD_is_interface'] == True]['ExpID'].unique()
    df_ppi = df_ppi[df_ppi['ExpID'].isin(expids_with_interface)].copy()
    df_residues = df_residues[df_residues['ExpID'].isin(expids_with_interface)].copy()
    df_contacts = df_contacts[df_contacts['ExpID'].isin(expids_with_interface)].copy()
    print(f"  Filtered datasets to {len(expids_with_interface)} ExpIDs with at least one interface residue.")

    # -----------------------------------------------------------------------------
    # Step 2: Aggregate T3 (Residue Properties)
    # -----------------------------------------------------------------------------
    print("\n## Step 2: Aggregating T3 (Residue Properties)")
    df_residues_interface = df_residues[df_residues["MD_is_interface"] == True].copy()
    print(f"  Number of interface C-alpha residues selected: {len(df_residues_interface)}")

    # --- Aggregate T3 features ---
    chemical_features = ["MD_MMGBSA_VdW", "MD_MMGBSA_Elec", "MD_MMGBSA_PolarSolv", "MD_MMGBSA_NonPolarSolv", "MD_RMSF"]
    agg_chem_mean = df_residues_interface.groupby("ExpID")[chemical_features].mean().add_suffix("_mean")
    agg_chem_sum = df_residues_interface.groupby("ExpID")[chemical_features].sum().add_suffix("_sum")

    agg_coord_rmsd_ca = df_residues_interface.groupby("ExpID").apply(
        lambda g: calculate_rmsd_from_centroid(g, 'MD_CA'), include_groups=False
    ).reset_index(name="Coords_RMSD_from_Centroid_CA")
    
    agg_planarity_rmsd_ca = df_residues_interface.groupby("ExpID").apply(
        lambda g: calculate_rmsd_to_best_fit_plane(g, 'MD_CA'), include_groups=False
    ).reset_index(name="Planarity_RMSD_CA")
    
    agg_coord_rmsd_com = df_residues_interface.groupby("ExpID").apply(
        lambda g: calculate_rmsd_from_centroid(g, 'MD_COM'), include_groups=False
    ).reset_index(name="Coords_RMSD_from_Centroid_COM")
    
    agg_planarity_rmsd_com = df_residues_interface.groupby("ExpID").apply(
        lambda g: calculate_rmsd_to_best_fit_plane(g, 'MD_COM'), include_groups=False
    ).reset_index(name="Planarity_RMSD_COM")

    rescode_proportions = calculate_proportions(df_residues_interface, "ResCode", "Prop_ResCode_")
    aminoacidtype_proportions = calculate_proportions(df_residues_interface, "AminoAcidType", "Prop_AminoAcidType_")
    mdss_proportions = calculate_proportions(df_residues_interface, "MD_Sec_Structure", "Prop_MD_SS_")

    # Consolidate secondary structure proportions
    mdss_proportions['Prop_MD_SS_He'] = mdss_proportions[[col for col in ['Prop_MD_SS_H', 'Prop_MD_SS_G', 'Prop_MD_SS_I'] if col in mdss_proportions]].sum(axis=1)
    mdss_proportions['Prop_MD_SS_Be'] = mdss_proportions[[col for col in ['Prop_MD_SS_E'] if col in mdss_proportions]].sum(axis=1)
    mdss_proportions['Prop_MD_SS_Co'] = mdss_proportions[[col for col in ['Prop_MD_SS_B', 'Prop_MD_SS_T', 'Prop_MD_SS_S', 'Prop_MD_SS_C'] if col in mdss_proportions]].sum(axis=1)
    
    mdss_proportions.drop(
        columns=[col for col in ['Prop_MD_SS_H', 'Prop_MD_SS_G', 'Prop_MD_SS_I', 'Prop_MD_SS_E', 'Prop_MD_SS_B', 'Prop_MD_SS_T', 'Prop_MD_SS_S', 'Prop_MD_SS_C'] if col in mdss_proportions], 
        inplace=True
    )

    agg_MD_interface_frac = df_residues.groupby("ExpID").agg(MD_Interface_Fraction=("MD_is_interface", "mean")).reset_index()
    interface_length = df_residues_interface.groupby("ExpID").size().reset_index(name="Interface_Length")

    # --- Merge all T3 aggregations ---
    dfs_to_merge_t3 = [
        agg_chem_mean, agg_chem_sum, agg_coord_rmsd_ca, agg_planarity_rmsd_ca, 
        agg_coord_rmsd_com, agg_planarity_rmsd_com, rescode_proportions, 
        aminoacidtype_proportions, mdss_proportions, agg_MD_interface_frac, interface_length
    ]
    
    # Concatenate all aggregated T3 DataFrames by ExpID
    #aggregated_T3 = pd.concat([df.set_index('ExpID') for df in dfs_to_merge_t3 if 'ExpID' in df.columns], axis=1).reset_index()
    #print(f"  Aggregated T3 features into {aggregated_T3.shape[1] - 1} columns.")
    aggregated_T3 = dfs_to_merge_t3[0]
    for df_to_merge in dfs_to_merge_t3[1:]:
        aggregated_T3 = pd.merge(aggregated_T3, df_to_merge, on="ExpID", how="outer")
    print(f"  Aggregated T3 shape: {aggregated_T3.shape}")


    # -----------------------------------------------------------------------------
    # Step 3: Aggregate T4 (Contacts)
    # -----------------------------------------------------------------------------
    print("\n## Step 3: Aggregating T4 (Residue Contacts)")

    # --- Create mapping of residues to interface status
    residue_interface_flags = df_residues.set_index(['ExpID', 'ProtID', 'ResID'])['MD_is_interface']

    # --- Map interface status to both residues in contacts
    df_contacts['is_interface_1'] = df_contacts.set_index(['ExpID', 'ProtIDA', 'ResIDA']).index.map(residue_interface_flags).fillna(False)
    df_contacts['is_interface_2'] = df_contacts.set_index(['ExpID', 'ProtIDB', 'ResIDB']).index.map(residue_interface_flags).fillna(False)

    # --- Filter: only contacts where BOTH residues are at the interface
    df_both_interface = df_contacts[
        (df_contacts['is_interface_1'] == True) & 
        (df_contacts['is_interface_2'] == True)
    ].copy()

    # Filter contacts with frequency > threshold
    freq_threshold = 0.30
    df_both_interface = df_both_interface[df_both_interface['Frequency'] > freq_threshold].copy()
    print(f"  Found {len(df_both_interface)} contacts with Frequency > {freq_threshold} and both residues at interface.")

    # --- Map fine-grained contact types to broader categories
    contact_type_mapping = {
        'sb':   'sb', 'pc':   'pc', 'ps':   'ps', 'ts':   'ts', 'vdw':  'vdw',
        'hp':   'hb', 'hb':   'hb', 'hbbb': 'hb', 'hbsb': 'hb', 'hbss': 'hb',
        'wb':   'wb', 'wb2':  'wb'
    }
    df_both_interface['ContactGroup'] = df_both_interface['ContactType'].map(contact_type_mapping)
    print("  Grouped detailed contact types into summary categories.")

    # --- Count contacts per ContactGroup per ExpID
    contact_group_counts = df_both_interface.groupby(['ExpID', 'ContactGroup']).size().reset_index(name='Count')

    # --- Pivot to wide format: one row per ExpID, one column per ContactGroup
    aggregated_counts = contact_group_counts.pivot_table(
        index='ExpID',
        columns='ContactGroup',
        values='Count',
        fill_value=0 # Fill NAs with 0 for ExpIDs that have no contacts of a certain type
    )

    # --- Add total contact count
    aggregated_counts['TotalContactCount'] = aggregated_counts.sum(axis=1)

    # --- Reset index so ExpID becomes a column
    aggregated_counts = aggregated_counts.reset_index()

    # --- Copy to final aggregated feature table
    aggregated_T4 = aggregated_counts.copy()
    print(f"  Aggregated contact counts into {aggregated_T4.shape[1] - 1} features per ExpID.")

    # --- Compute interface length (number of interface residues per ExpID)
    # This is re-calculated here for T4 aggregation context, but also exists from T3.
    # We will use the one from T3 for final merge to ensure consistency.
    interface_lengths_t4 = df_residues[df_residues['MD_is_interface'] == True].groupby('ExpID').size().reset_index(name='InterfaceLength')

    # --- Merge interface lengths
    aggregated_T4 = aggregated_T4.merge(interface_lengths_t4, on='ExpID', how='left')

    # --- Compute contact density: contacts per interface residue
    aggregated_T4['Contact_per_Interface'] = aggregated_T4['TotalContactCount'] / aggregated_T4['InterfaceLength']
    print(f"  Final T4 feature table has {aggregated_T4.shape[1] - 1} features including contact density.")


    # -----------------------------------------------------------------------------
    # Step 5: Add contact type values (contact + alpha) / (interfacelength + beta)
    # -----------------------------------------------------------------------------
    print("\n Step 5: Adding contact types per interface length")

    vars_to_normalize = ["hb", "pc", "ps", "sb", "ts", "vdw", "wb"]
    
    for var in vars_to_normalize:
        new_col_name = f"Prop_{var}"
        aggregated_T4[new_col_name] = (aggregated_T4[var] + 1.5) / (aggregated_T4['InterfaceLength'] + 3)
    print(" Contact counts per interface length added to the data frame.")
    
    
    # -----------------------------------------------------------------------------
    # Step 4: Merge All Data and Post-process
    # -----------------------------------------------------------------------------
    print("\n## Step 4: Merging all data and post-processing")
    # Merge T3 and T4 results
    aggregated_T3_T4 = pd.merge(aggregated_T3, aggregated_T4, on="ExpID", how="outer")

    # Merge with T2 (PPI Complexes)
    df_ppi['ExpID'] = df_ppi['ExpID'].astype(str)
    aggregated_T3_T4['ExpID'] = aggregated_T3_T4['ExpID'].astype(str)
    final_aggregated_df = pd.merge(aggregated_T3_T4, df_ppi, on="ExpID", how="left")
    print(f"  Final merged shape: {final_aggregated_df.shape}")

    # --- Post-processing ---
    df_processed = final_aggregated_df.copy()
    
    # Drop rows where 'InterfaceLength' is NaN (ExpIDs with no interface residues despite initial filtering)
    df_processed = df_processed.dropna(subset=["InterfaceLength"]) 
    print(f"  Dropped rows with NaN 'InterfaceLength'. New shape: {df_processed.shape}")
    
    df_processed.to_csv("aggregated_features_RAW_untransformed.csv", index=False)
    print("  Saved raw, untransformed aggregated data to 'aggregated_features_RAW_untransformed.csv'.")


    # -----------------------------------------------------------------------------
    # Step 5: Transformations and Scaling
    # -----------------------------------------------------------------------------
    print("\n## Step 5: Applying transformations and scaling")
    # Define features for transformation, now including T4 features
    yeo_johnson_feats = [
        col for col in df_processed.columns 
        if col.startswith("MD_MMGBSA_") or col == 'Interface_Length' or col.startswith('MD_RMSF') or col.startswith('Freq_') or col == 'TotalContactCount'
    ]
    boxcox_feats = [
        col for col in df_processed.columns 
        if col in ['Coords_RMSD_from_Centroid_CA', 'Coords_RMSD_from_Centroid_COM', 'Planarity_RMSD_CA', 'Planarity_RMSD_COM']
    ]
    
    logit_feats = [
        col for col in df_processed.columns 
        if col.startswith('Prop_') or col == 'MD_Interface_Fraction' or col =='Contact_per_Interface'
    ]
    all_features_to_transform = yeo_johnson_feats + boxcox_feats + logit_feats
    
    # Filter out features that do not exist in the DataFrame
    all_features_to_transform = [f for f in all_features_to_transform if f in df_processed.columns]
    print(f"  Identified {len(all_features_to_transform)} features for transformation.")

    # Plot original distributions
    plot_feature_distributions(
        df=df_processed,
        columns_to_plot=all_features_to_transform,
        main_title="Original Feature Distributions",
        filename="original_feature_distributions.png",
        title_suffixes={col: '(Original)' for col in all_features_to_transform}
    )

    # --- Apply Transformations ---
    transformed_cols = []
    for col in all_features_to_transform:
        # Skip if column has less than 2 unique values (no variance for transformation)
        if df_processed[col].nunique() < 2:
            print(f"  Skipping transformation for '{col}' due to insufficient unique values.")
            continue 

        if col in yeo_johnson_feats:
            pt = PowerTransformer(method='yeo-johnson', standardize=False)
            df_processed[col] = pt.fit_transform(df_processed[[col]]).flatten()
            transformed_cols.append(col)
        elif col in boxcox_feats:
            numeric_col = pd.to_numeric(df_processed[col], errors='coerce')
            # Add a small shift if min value is non-positive for Box-Cox
            shift = abs(numeric_col.min()) + 0.01 if numeric_col.min() <= 0 else 0
            df_processed[col] = sp_stats.boxcox(numeric_col + shift)[0]
            transformed_cols.append(col)
        elif col in logit_feats:
            numeric_col = pd.to_numeric(df_processed[col], errors='coerce')
            # Clip values to avoid logit(0) or logit(1) which result in inf/-inf
            df_processed[col] = logit(np.clip(numeric_col, 1e-6, 1 - 1e-6))
            transformed_cols.append(col)
    print(f"  Applied transformations to {len(transformed_cols)} features.")

    # Plot transformed distributions
    plot_feature_distributions(
        df=df_processed,
        columns_to_plot=transformed_cols,
        main_title="Feature Distributions After Transformation",
        filename="transformed_distributions.png",
        title_suffixes={col: '(Transformed)' for col in transformed_cols}
    )

    # --- Apply Standardization (Scaling) ---
    if transformed_cols: # Only scale if there are columns to scale
        data_to_scale = df_processed[transformed_cols].copy()
        
        # Impute any remaining NaNs/Infs with the median before scaling
        for col in data_to_scale.columns:
            if data_to_scale[col].isnull().any() or np.isinf(data_to_scale[col]).any():
                median_val = data_to_scale[col][np.isfinite(data_to_scale[col])].median()
                data_to_scale[col] = data_to_scale[col].fillna(median_val).replace([np.inf, -np.inf], median_val)

        scaler = StandardScaler()
        df_processed[transformed_cols] = scaler.fit_transform(data_to_scale)
        print(f"  Scaled {len(transformed_cols)} features.")
    else:
        print("  No features were transformed, skipping standardization.")

    # -----------------------------------------------------------------------------
    # Step 6: Final Plots and Saving
    # -----------------------------------------------------------------------------
    print("\n## Step 6: Generating final plots and saving data")
    # Plot final distributions
    plot_feature_distributions(
        df=df_processed,
        columns_to_plot=transformed_cols,
        main_title="Final Processed Feature Distributions",
        filename="final_feature_distributions.png",
        title_suffixes={col: '(Transformed & Scaled)' for col in transformed_cols}
    )

    # --- Save Final Data ---
    df_processed.to_csv("aggregated_interface_features_processed.csv", index=False)
    print(f"  Final data with {df_processed.shape[1]} columns saved to 'aggregated_interface_features_processed.csv'.")
    
    if transformed_cols:
        df_processed[transformed_cols].to_csv("aggregated_features_only_processed.csv", index=False)
        print(f"  Processed features only ({len(transformed_cols)} features) saved to 'aggregated_features_only_processed.csv'.")



















